{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug invetory-retail-system with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nx", "serve", "invetory-retail-system"],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/invetory-retail-system/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    },
